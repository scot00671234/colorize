# Database (required for auth)
DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# Auth API
PORT=3001
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
CONFIRMATION_EXPIRES_MINUTES=1440
# Password reset link expiry (minutes). Default 60.
# PASSWORD_RESET_EXPIRES_MINUTES=60

# Frontend URL (for verification links in emails). REQUIRED in production: set to your real app URL or confirmation links will point to localhost and break.
# Local:
APP_BASE_URL=http://localhost:5173
# Production (e.g.):
# APP_BASE_URL=https://your-app.com

# Resend (sign-up confirmation email). If unset, verification link is only logged to the server console.
# Production: Resend only sends to other addresses if you verify a domain and set RESEND_FROM to an email on that domain.
# RESEND_API_KEY=re_...
# RESEND_FROM=bioqz <noreply@bioqz.com>

# Stripe (optional – leave unset to return "Billing not configured" from upgrade/cancel)
# 1. Create an account at https://dashboard.stripe.com and get your keys.
# 2. Developers → API keys: copy "Secret key" (use sk_test_... in dev, sk_live_... in prod).
# STRIPE_SECRET_KEY=sk_test_...

# 3. Products → create a Product (e.g. "Pro" or "Enterprise") → add a Price (recurring). Copy the full Price ID.
#    It looks like price_1ABC123xyz... (long string from Stripe). Short values like price_29 are placeholders and will fail.
# STRIPE_PRICE_PRO=price_1xxxxxxxxxxxxxxxxxxxxx
# STRIPE_PRICE_ENTERPRISE=price_1xxxxxxxxxxxxxxxxxxxxx

# 4. Webhooks (do this so checkout and subscription updates work): Developers → Webhooks → Add endpoint.
#    URL: https://your-api-domain.com/api/auth/stripe-webhook  (or use Stripe CLI for local: stripe listen --forward-to localhost:3001/api/auth/stripe-webhook)
#    Events: checkout.session.completed, customer.subscription.created, customer.subscription.updated, customer.subscription.deleted
#    Copy "Signing secret" (whsec_...) into STRIPE_WEBHOOK_SECRET. See docs/STRIPE_WEBHOOK.md.
# STRIPE_WEBHOOK_SECRET=whsec_...

# Replicate (photo colorize + restore). Get token at https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=r8_...

# Storage (S3 or R2). Required for photo uploads. Use MinIO or R2 for local dev.
# STORAGE_BUCKET=your-bucket
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY_ID=
# STORAGE_SECRET_ACCESS_KEY=
# STORAGE_ENDPOINT=   # optional; set for R2 or MinIO

# REDIS_URL=  # optional; for job queue (otherwise in-memory)

# Optional: frontend .env (Vite). Leave unset in dev (defaults to http://localhost:3001) and in production single-server (same-origin).
# VITE_API_URL=http://localhost:3001
