# =============================================================================
# Core (required for auth + dashboard)
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/your_database

# Server
PORT=3001
NODE_ENV=development
# Production: NODE_ENV=production — required for static SPA + security headers + startup checks (DATABASE_URL + JWT_SECRET).

# Auth — use a long random string in production (32+ chars)
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
CONFIRMATION_EXPIRES_MINUTES=1440
# PASSWORD_RESET_EXPIRES_MINUTES=60

# Public URL of the SPA (emails, Stripe redirects, OAuth). No trailing slash.
# Local dev:
APP_BASE_URL=http://localhost:5173
# Production:
# APP_BASE_URL=https://colorizer.cc

# Optional: if API is on a different host than the SPA (rare with this stack)
# BACKEND_URL=https://api.colorizer.cc

# CORS — production only; comma-separated if you serve the app on multiple origins (e.g. www + apex)
# Defaults to APP_BASE_URL if unset.
# CORS_ORIGINS=https://colorizer.cc,https://www.colorizer.cc

# Postgres TLS (Neon, Supabase, RDS, many VPS providers)
# DATABASE_SSL=true
# For some providers you may need:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
# PG_POOL_MAX=20

# =============================================================================
# Email (Resend) — verification & password reset
# =============================================================================
# RESEND_API_KEY=re_...
# RESEND_FROM=Colorizer <noreply@colorizer.cc>

# =============================================================================
# Stripe — Starter / Pro / Studio subscriptions (optional)
# =============================================================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_STUDIO=price_...
# (Legacy: STRIPE_PRICE_ELITE is used as Studio if STRIPE_PRICE_STUDIO is unset.)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Webhook URL: https://colorizer.cc/api/auth/stripe-webhook
# See docs/STRIPE_WEBHOOK.md

# =============================================================================
# Google OAuth (optional)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Redirect: http://localhost:3001/api/auth/google/callback (adjust host for prod)

# =============================================================================
# AI images — Replicate (colorize + restore)
# =============================================================================
# REPLICATE_API_TOKEN=r8_...
# Optional model overrides (owner/model:version)
# REPLICATE_COLORIZE_MODEL=
# REPLICATE_RESTORE_MODEL=

# =============================================================================
# Frontend (Vite) — optional
# =============================================================================
# Same-origin in production (single server). Set only if API is on another origin:
# VITE_API_URL=http://localhost:3001
# Canonical site URL for SEO (production)
# VITE_SITE_URL=https://colorizer.cc

# =============================================================================
# Ops
# =============================================================================
# Optional Redis (reserved for future caching)
# REDIS_URL=

